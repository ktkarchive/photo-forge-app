{
  "name": "ktk-select-gui",
  "version": "0.1.0-beta1",
  "private": true,
  "description": "ktk.select macOS GUI (Stitch-guided Carbon Dark)",
  "main": "main.cjs",
  "scripts": {
    "prepare:embedded": "bash scripts/prepare-embedded.sh",
    "dev": "npm run prepare:embedded && electron .",
    "pack:mac:unsigned": "npm run prepare:embedded && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "stitch:spec": "cat STITCH_UI_SPEC.txt"
  },
  "devDependencies": {
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.ktk.select.gui",
    "productName": "ktk.select",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "files": [
      "main.cjs",
      "preload.cjs",
      "renderer/**/*",
      "embedded/**/*"
    ],
    "extraMetadata": {
      "main": "main.cjs"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "artifactName": "ktk.select-gui-${version}-${arch}.${ext}",
      "category": "public.app-category.photography",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    }
  }
}
