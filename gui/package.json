{
  "name": "photo-forge-gui",
  "version": "0.0.1",
  "private": true,
  "description": "Photo Forge macOS GUI (Stitch-guided Carbon Dark)",
  "main": "main.cjs",
  "scripts": {
    "prepare:embedded": "bash scripts/prepare-embedded.sh",
    "dev": "npm run prepare:embedded && electron .",
    "pack:mac:unsigned": "npm run prepare:embedded && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "stitch:spec": "cat STITCH_UI_SPEC.txt"
  },
  "devDependencies": {
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.photoforge.gui",
    "productName": "Photo Forge",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "files": [
      "main.cjs",
      "preload.cjs",
      "renderer/**/*",
      "embedded/**/*"
    ],
    "extraMetadata": {
      "main": "main.cjs"
    },
    "icon": "build/icon.icns",
    "mac": {
      "target": [
        "dmg"
      ],
      "artifactName": "Photo-Forge-${version}-${arch}.${ext}",
      "category": "public.app-category.photography",
      "icon": "build/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "icon": "build/icon.icns"
    }
  }
}
